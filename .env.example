# Snowflake Connection Configuration
# Copy this file to .env and fill in your actual credentials

SNOWFLAKE_USER=your_username
SNOWFLAKE_PASSWORD=your_password
SNOWFLAKE_ACCOUNT=your_account_identifier
SNOWFLAKE_WAREHOUSE=your_warehouse_name
SNOWFLAKE_DATABASE=your_database_name
SNOWFLAKE_SCHEMA=your_schema_name
SNOWFLAKE_ROLE=your_role_name

# Optional: AWS Credentials (for S3 operations)
# AWS_ACCESS_KEY_ID=your_aws_key
# AWS_SECRET_ACCESS_KEY=your_aws_secret

# Optional: GCP Credentials (for GCS operations)
# GCP_PROJECT_ID=your_project_id
# GCP_KEY_PATH=/path/to/service-account-key.json

# Optional: Azure Credentials (for Azure Blob operations)
# AZURE_STORAGE_ACCOUNT=your_storage_account
# AZURE_SAS_TOKEN=your_sas_token